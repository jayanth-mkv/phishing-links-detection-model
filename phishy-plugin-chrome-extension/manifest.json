{
  "name": "Phishy",
  "description": "Local research companion for the phishing URL scoring API.",
  "version": "1.0",
  "author": "JayanthMKV",
  "manifest_version": 3,
  "permissions": ["tabs", "notifications", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Phishy Detect",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "content_scripts": [
    {
      "js": ["scripts/contentscript.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "web_accessible_resources":[{
    "resources":[
        "icons/128.png",
        "icons/48.png"
    ],
    "matches":["<all_urls>"]
  }]
}
