HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=false

# Disabled by default: scoring remains lexical/offline and live-page-dependent
# features use the model's unavailable sentinel. See the README before enabling.
ENABLE_NETWORK_FEATURES=false

# Required only for the trusted feedback endpoint.
FEEDBACK_API_KEY=replace-with-a-long-random-feedback-key

# Use Redis or another shared backend when running more than one process.
RATELIMIT_STORAGE_URI=memory://
